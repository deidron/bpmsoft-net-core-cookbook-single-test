# Copy this file to `.devcontainer/devcontainer.env` (gitignored) and fill it in.
# Picked up by scripts/fetch-platform-libs.sh inside the dev container.
#
# Alternatives: set these as host env vars (devcontainer.json reads
# ${localEnv:...}) or, in Codespaces, as Codespaces secrets. NEVER commit a token.

# Token with READ access to the private platform-libs repo.
GH_PAT=

# owner/name of the private platform-libs repo (required — ask a maintainer).
PLATFORM_LIBS_REPO=
